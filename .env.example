# Razorpay – used by scripts/razorpay_order_server.mjs (Key Secret never in Flutter)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# Jira API – used by scripts/create-jira-tickets.mjs
# Copy to .env and fill in. Do not commit .env.

JIRA_DOMAIN=niroopk.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=

# Project key: S1 (existing) or SAAS (new company-style project)
JIRA_PROJECT_KEY=SAAS

# Set to true to try creating the project via API (requires Jira admin)
# JIRA_CREATE_PROJECT=false
