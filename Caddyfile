:{$PORT:8080} {
  root * /srv
  encode zstd gzip
  file_server

  # Entry + app bundles change every deploy — never long-cache (fixes stale site in normal tabs).
  @noCacheEntry {
    path / /index.html
    path /flutter_bootstrap.js
    path /flutter.js
    path /flutter_service_worker.js
    path /main.dart.js
    path /main.dart.wasm
    path /manifest.json
    path /recrip-build.json
  }
  header @noCacheEntry Cache-Control "no-cache, no-store, must-revalidate"

  # Hashed / versioned static blobs only (do not match *.js globally — that cached old main.dart.js).
  @immutableAssets {
    path /assets/*
    path /canvaskit/*
    path *.css
    path *.png
    path *.jpg
    path *.jpeg
    path *.webp
    path *.svg
    path *.ico
    path *.woff
    path *.woff2
  }
  header @immutableAssets Cache-Control "public, max-age=31536000, immutable"

  try_files {path} /index.html
}
